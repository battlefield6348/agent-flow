# Agent Flow 設定檔範例 (完全配置驅動：靈活自訂 Session、Profile 與 AI Provider)
gitlab_url: "https://gitlab.example.com"
interval_seconds: 60
check_ci_success: true

# cao-server 連線位址
cao_server_url: "http://localhost:9889"

allowed_projects:
  - "group/project-a"
allowed_mr_authors:
  - "developer1"

# 完全由使用者在 config 中自由決定 Agent 識別碼、Session 名稱、Agent Profile 與 Provider
agents:
  - id: "reviewer"
    gitlab_token: "glpat-reviewer-token-xxxxxx"
    cao_session_name: "gitlab-reviewer"         # 自訂要建立/對接的 CAO Session 名稱
    cao_agent_profile: "review_supervisor"      # 自訂 CAO Agent Profile (如 review_supervisor, developer)
    cao_provider: "kiro_cli"                    # 自訂 AI Provider (如 codex, kiro_cli, claude_code)

  - id: "coder"
    gitlab_token: "glpat-coder-token-yyyyyy"
    cao_session_name: "gitlab-coder"            # 自訂要建立/對接的 CAO Session 名稱
    cao_agent_profile: "code_supervisor"        # 自訂 CAO Agent Profile
    cao_provider: "codex"                       # 自訂 AI Provider
